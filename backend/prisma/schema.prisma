generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PARENT
  TUTOR
}

enum CaseStatus {
  OPEN
  MATCHED
  CLOSED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownedCases   Case[]        @relation("CaseOwner")
  invitations  CaseInvitation[]
  documents    Document[]
  tutorProfile TutorProfile?
  resetToken   String?
  resetTokenExpiresAt DateTime?

  @@index([role])
}

model Case {
  id            String           @id @default(uuid())
  title         String
  subject       String
  level         String
  location      String?
  budgetPerHour Float
  status        CaseStatus       @default(OPEN)
  ownerId       String
  owner         User             @relation("CaseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitations   CaseInvitation[]
  documents     Document[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([ownerId])
  @@index([subject])
  @@index([level])
  @@index([status])
  @@index([title])
}

model CaseInvitation {
  id        String    @id @default(uuid())
  caseId    String
  tutorId   String
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tutor     User      @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  invitedAt DateTime  @default(now())
  revokedAt DateTime?

  @@unique([caseId, tutorId])
  @@index([tutorId])
  @@index([caseId])
}

model TutorProfile {
  id              String     @id @default(uuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  qualifications  String     @default("")
  experiences     String     @default("")
  documents       Document[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([displayName])
}

enum DocumentOwnerType {
  CASE
  TUTOR_PROFILE
}

model Document {
  id               String            @id @default(uuid())
  originalFilename String
  storedFilename   String            @unique
  mimeType         String
  size             Int
  uploadedById     String
  uploadedBy       User              @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  ownerType        DocumentOwnerType
  caseId           String?
  case             Case?             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tutorProfileId   String?
  tutorProfile     TutorProfile?     @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())

  @@index([caseId])
  @@index([tutorProfileId])
  @@index([uploadedById])
}
